import("std/list") as list
import("std/str") as str
import("../src/render/ppm") as ppm

test "blank image has correct dimensions" {
  let img = ppm.blank(3, 2, { r: 0.0, g: 0.0, b: 0.0 }) in
  img.width == 3 && img.height == 2
}

test "blank image has one rect covering full canvas" {
  let img = ppm.blank(3, 2, { r: 0.0, g: 0.0, b: 0.0 }) in
  list.len(img.rects) == 1
}

test "fill_rect adds a rect with correct color" {
  let img0 = ppm.blank(4, 4, { r: 0.0, g: 0.0, b: 0.0 }) in
  let img1 = ppm.fill_rect(img0, 1, 1, 2, 2, { r: 1.0, g: 0.0, b: 0.0 }) in
  let rect = list.get(img1.rects, 1) in
  rect.x == 1 && rect.y == 1 && rect.w == 2 && rect.h == 2 && rect.color.r == 1.0
}

test "color_at reads correct color from filled rect" {
  let img0 = ppm.blank(4, 4, { r: 0.0, g: 0.0, b: 0.0 }) in
  let img1 = ppm.fill_rect(img0, 1, 1, 2, 2, { r: 1.0, g: 0.0, b: 0.0 }) in
  let c = ppm.color_at(img1.rects, 1, 1, { r: 0.0, g: 0.0, b: 0.0 }) in
  c.r == 1.0 && c.g == 0.0 && c.b == 0.0
}

test "ppm header starts with P3" {
  let img = ppm.blank(1, 1, { r: 1.0, g: 0.0, b: 0.0 }) in
  let s = ppm.encode_ppm(img) in
  str.starts_with(s, "P3\n")
}
