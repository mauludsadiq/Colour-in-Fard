import("std/list") as list
import("../render/ppm") as ppm

fn horizontal_strip(width, height, sample_fn) {
  let img0 = ppm.blank(width, height, { r: 0.0, g: 0.0, b: 0.0 }) in
  list.fold(list.range(0, width), img0, fn(img, x) {
    let rgb = sample_fn(x, width) in
    ppm.fill_rect(img, x, 0, 1, height, rgb)
  })
}

{
  horizontal_strip: horizontal_strip
}
